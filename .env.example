# ══════════════════════════════════════════════════════════════
# SemiAnalysis Task — Environment Variables
# ══════════════════════════════════════════════════════════════

# Model served by SGLang (FP8 quantised MoE)
MODEL_PATH=zai-org/GLM-4.5-Air-FP8

# LLM proxy target (the proxy sits on :8001, backend router on :8000)
ANTHROPIC_BASE_URL=http://localhost:8001/v1
ANTHROPIC_API_KEY=dummy

# ── SGLang 2P2D Disaggregated Serving ────────────────────────
HOST_IP=0.0.0.0
MAX_MODEL_LEN=32768
TP_SIZE=1

# Ports for prefill / decode / router
PREFILL_PORT_1=30000
PREFILL_PORT_2=30002
DECODE_PORT_1=30001
DECODE_PORT_2=30003
ROUTER_PORT=8000

# ── Mooncake Transfer Engine ────────────────────────────────
# Protocol: "rdma" for production (requires RDMA-capable NICs), "tcp" for dev
MOONCAKE_PROTOCOL=tcp
# RDMA device names (comma-separated), leave empty for auto-detect
MOONCAKE_DEVICE=
# Memory contributed to the distributed KV-cache pool
MOONCAKE_GLOBAL_SEG=4gb
MOONCAKE_MASTER_PORT=50051
